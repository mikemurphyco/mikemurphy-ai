---
import type { Article } from '../../lib/articles';
import { formatDate, getArticleTopicTerms, tutorialUrl } from '../../lib/articles';

interface Props {
  tutorial: Article;
}

const { tutorial } = Astro.props;
const terms = getArticleTopicTerms(tutorial).slice(0, 3);
---

<article class="mm-card group h-full overflow-hidden">
  {tutorial.data.featuredImage && (
    <a href={tutorialUrl(tutorial)} class="block aspect-video overflow-hidden bg-[var(--mm-navy)]">
      <img
        src={tutorial.data.featuredImage}
        alt=""
        loading="lazy"
        class="h-full w-full object-cover opacity-95 transition duration-200 group-hover:scale-[1.015] group-hover:opacity-100"
      />
    </a>
  )}
  <div class="flex min-h-full flex-col p-5">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-muted)]">
      {formatDate(tutorial.data.pubDate)}
    </p>
    <h2 class="mt-3 font-mono text-xl font-bold uppercase leading-tight tracking-normal text-[var(--mm-navy)]">
      <a href={tutorialUrl(tutorial)} class="hover:underline">{tutorial.data.title}</a>
    </h2>
    {tutorial.data.description && (
      <p class="mt-3 line-clamp-3 text-sm leading-6 text-[var(--mm-muted)]">{tutorial.data.description}</p>
    )}
    {terms.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2">
        {terms.map((term) => <span class="mm-pill">{term}</span>)}
      </div>
    )}
  </div>
</article>
