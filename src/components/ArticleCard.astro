---
import type { Article } from '../lib/articles';
import { contentUrl, formatDate, getArticleTopicTerms } from '../lib/articles';

interface Props {
  article: Article;
  showImage?: boolean;
}

const { article, showImage = true } = Astro.props;
const terms = getArticleTopicTerms(article).slice(0, 3);
const url = contentUrl(article);
---

<article class="group grid gap-5 border-b border-[var(--mm-border)] py-6 sm:grid-cols-[13rem_1fr] sm:items-start">
  {showImage && article.data.featuredImage ? (
    <a href={url} class="block aspect-video overflow-hidden rounded bg-[var(--mm-navy)]">
      <img
        src={article.data.featuredImage}
        alt=""
        loading="lazy"
        class="h-full w-full object-cover transition duration-200 group-hover:scale-[1.025]"
      />
    </a>
  ) : (
    <div class="hidden aspect-video rounded bg-[var(--mm-border)] sm:block" aria-hidden="true"></div>
  )}
  <div class="min-w-0">
    <p class="text-sm text-[var(--mm-muted)]">
      {formatDate(article.data.pubDate)}
      <span class="mx-2 opacity-40">/</span>
      {article.data.contentEra === 'ai' ? 'AI Era' : 'Archive'}
    </p>
    <h2 class="mt-2 text-xl font-semibold leading-snug text-[var(--color-text-primary)]">
      <a href={url} class="hover:underline">{article.data.title}</a>
    </h2>
    {article.data.description && (
      <p class="mt-2 line-clamp-2 text-sm leading-6 text-[var(--mm-muted)]">{article.data.description}</p>
    )}
    {terms.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {terms.map((term) => (
          <span class="mm-pill">{term}</span>
        ))}
      </div>
    )}
  </div>
</article>
