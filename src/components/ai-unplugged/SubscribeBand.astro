---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section
  class:list={[
    'border-y border-[var(--mm-navy)] bg-[var(--mm-orange)] text-[var(--mm-chalk)]',
    compact ? 'py-10' : 'py-16',
  ]}
>
  <div class="mm-container grid items-center gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-12">
    <div>
      <p class="mm-eyebrow text-[var(--mm-chalk)] opacity-85">AI Unplugged · weekly</p>
      <h2
        class:list={[
          'mt-3 max-w-[16ch] font-mono font-bold uppercase leading-none tracking-[-0.03em] text-[var(--mm-chalk)]',
          compact ? 'text-3xl md:text-4xl' : 'text-4xl md:text-5xl',
        ]}
      >
        Newsletter for AI Builders
      </h2>
      <p class="mt-4 max-w-[44ch] text-lg leading-snug opacity-92">
        One practical email with the news, tools, terms, and tutorials worth remembering. Beehiiv sends it; Astro owns the archive.
      </p>
    </div>
    <form
      class="grid gap-3 rounded-[var(--radius-md)] border border-[var(--mm-navy)] bg-[var(--mm-chalk)] p-6 text-[var(--mm-navy)] shadow-[4px_4px_0_var(--mm-navy)]"
      action="https://magic.beehiiv.com/v1/dbf3263d-90ad-4aa7-ac97-7adc027f69f3"
      method="get"
    >
      <label for="ai-unplugged-email" class="font-mono text-xs font-bold uppercase tracking-[0.14em]">
        Email address
      </label>
      <input
        id="ai-unplugged-email"
        name="email"
        type="email"
        required
        placeholder="you@example.com"
        autocomplete="email"
        class="w-full rounded-[var(--radius-md)] border border-[var(--mm-navy)] bg-[var(--mm-cream)] px-3.5 py-3 text-base text-[var(--mm-navy)] shadow-[2px_2px_0_var(--mm-navy)] outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--mm-orange)]"
      />
      <button class="mm-button w-full" type="submit">Subscribe to AI Unplugged</button>
      <p class="text-xs leading-5 text-[var(--mm-muted)]">No spam. Reply-friendly. Easy to leave.</p>
    </form>
  </div>
</section>
