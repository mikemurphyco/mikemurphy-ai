---
import type { AiUnpluggedIssue } from '../../lib/articles';
import { formatDate, issueUrl } from '../../lib/articles';

interface Props {
  issue: AiUnpluggedIssue;
  compact?: boolean;
}

const { issue, compact = false } = Astro.props;
const paddedIssue = String(issue.data.issue).padStart(3, '0');
---

<article class="mm-card grid gap-4 p-5 sm:grid-cols-[4rem_1fr_auto] sm:items-center">
  <a
    href={issueUrl(issue)}
    class="grid size-16 place-items-center rounded bg-[var(--mm-orange)] text-center font-mono font-bold text-[var(--color-text-primary)]"
    aria-label={`Read AI Unplugged issue ${paddedIssue}`}
  >
    <span>
      <span class="block text-[0.58rem] uppercase tracking-[0.12em]">Issue</span>
      <span class="block text-2xl leading-none">{paddedIssue}</span>
    </span>
  </a>
  <div>
    <p class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-muted)]">
      {formatDate(issue.data.publishedAt)}
    </p>
    <h2 class="mt-2 font-mono text-xl font-bold uppercase leading-tight tracking-normal text-[var(--color-text-primary)]">
      <a href={issueUrl(issue)} class="hover:underline">{issue.data.subject}</a>
    </h2>
    {!compact && <p class="mt-2 max-w-3xl text-sm leading-6 text-[var(--mm-muted)]">{issue.data.summary}</p>}
    {issue.data.topics.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {issue.data.topics.slice(0, 4).map((topic) => <span class="mm-pill">{topic}</span>)}
      </div>
    )}
  </div>
  <a href={issueUrl(issue)} class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange-deep)] hover:underline">
    Read
  </a>
</article>
