---
import { SITE_SOCIAL, type SocialId } from '../lib/site';

interface Props {
  variant?: 'default' | 'compact' | 'footer';
  class?: string;
}

const { variant = 'default', class: className = '' } = Astro.props;

const showLabels = variant === 'default';
const isFooter = variant === 'footer';

const icons: Record<SocialId, string> = {
  youtube:
    'M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.5 31.5 0 0 0 0 12a31.5 31.5 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.5 31.5 0 0 0 24 12a31.5 31.5 0 0 0-.5-5.8zM9.8 15.5v-7l6.3 3.5-6.3 3.5z',
  podcast:
    'M12 1a7 7 0 0 0-7 7v3a7 7 0 0 0 5 6.7V21H7v2h10v-2h-3v-3.3A7 7 0 0 0 19 11V8a7 7 0 0 0-7-7zm-5 7a5 5 0 0 1 10 0v3a5 5 0 0 1-10 0V8zm5 8a3 3 0 0 0 3-3V8a3 3 0 0 0-6 0v5a3 3 0 0 0 3 3z',
  x: 'M18.2 2H21l-6.6 7.5L22 22h-6.2l-4.9-6.4L5.4 22H2.6l7-8L2 2h6.3l4.4 5.8L18.2 2zm-1.1 18h1.7L7 3.9H5.2L17.1 20z',
  linkedin:
    'M4.98 3.5A2.5 2.5 0 1 1 0 3.5a2.5 2.5 0 0 1 4.98 0zM.5 8.5h4.9V23H.5V8.5zM8.5 8.5h4.7v2h.1c.7-1.2 2.3-2.5 4.7-2.5 5 0 5.9 3.3 5.9 7.6V23h-4.9v-6.6c0-1.6 0-3.6-2.2-3.6s-2.5 1.7-2.5 3.5V23H8.5V8.5z',
  instagram:
    'M12 2.2c3.2 0 3.6 0 4.9.1 3.3.1 4.8 1.7 4.9 4.9.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 3.2-1.7 4.8-4.9 4.9-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-3.3-.1-4.8-1.7-4.9-4.9-.1-1.3-.1-1.7-.1-4.9s0-3.6.1-4.9C2.3 4 3.9 2.4 7.1 2.3 8.4 2.2 8.8 2.2 12 2.2zm0 1.8c-3.2 0-3.5 0-4.8.1-2.2.1-3.3 1.2-3.4 3.4-.1 1.2-.1 1.6-.1 4.8s0 3.5.1 4.8c.1 2.2 1.2 3.3 3.4 3.4 1.2.1 1.6.1 4.8.1s3.5 0 4.8-.1c2.2-.1 3.3-1.2 3.4-3.4.1-1.2.1-1.6.1-4.8s0-3.5-.1-4.8c-.1-2.2-1.2-3.3-3.4-3.4-1.3-.1-1.6-.1-4.8-.1zm0 3.2a5.1 5.1 0 1 1 0 10.2 5.1 5.1 0 0 1 0-10.2zm0 1.8a3.3 3.3 0 1 0 0 6.6 3.3 3.3 0 0 0 0-6.6zm5.3-2.1a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4z',
  github:
    'M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.6-4-1.6-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.9 1.2 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z',
};
---

<nav
  aria-label="Social links"
  class:list={[
    'social-links',
    `social-links--${variant}`,
    isFooter && 'social-links--on-dark',
    className,
  ]}
>
  <ul class="social-links__list">
    {
      SITE_SOCIAL.map((item) => (
        <li>
          <a
            href={item.href}
            class="social-links__link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label={item.label}
          >
            <svg class="social-links__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d={icons[item.id]} />
            </svg>
            {showLabels && <span class="social-links__label">{item.label}</span>}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .social-links__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .social-links__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border: 2px solid var(--color-border-strong);
    background: var(--color-bg-surface);
    color: var(--color-text-primary);
    text-decoration: none;
    transition:
      background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }

  .social-links--default .social-links__link {
    min-height: 2.75rem;
    padding: 0.55rem 0.9rem;
    box-shadow: var(--shadow-cut);
  }

  .social-links--compact .social-links__link,
  .social-links--footer .social-links__link {
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
  }

  .social-links--footer .social-links__link {
    border-color: color-mix(in srgb, var(--mm-cream) 28%, transparent);
    background: transparent;
    color: var(--mm-cream);
  }

  .social-links__icon {
    width: 1.1rem;
    height: 1.1rem;
    flex-shrink: 0;
  }

  .social-links__label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .social-links__link:hover {
    background: var(--mm-orange);
    border-color: var(--mm-orange);
    color: var(--mm-chalk);
    transform: translate(-1px, -1px);
  }

  .social-links--footer .social-links__link:hover {
    background: var(--mm-orange);
    border-color: var(--mm-orange);
    color: var(--mm-chalk);
  }

  .social-links__link:focus-visible {
    outline: 2px solid var(--mm-orange);
    outline-offset: 3px;
  }
</style>
