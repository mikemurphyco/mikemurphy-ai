---
---

<button
  type="button"
  id="mm-theme-toggle"
  class="mm-theme-toggle"
  aria-label="Switch to dark mode"
  title="Switch to dark mode"
>
  <!-- Moon: shown in light mode (action = go dark) -->
  <svg class="mm-theme-toggle__icon mm-theme-toggle__icon--moon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 14.5A8.5 8.5 0 1 1 9.5 3 7 7 0 0 0 21 14.5z"></path>
  </svg>
  <!-- Sun: shown in dark mode (action = go light) — line style matching common light-mode icons -->
  <svg class="mm-theme-toggle__icon mm-theme-toggle__icon--sun" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="3.25"></circle>
    <path d="M12 2.75v2.1M12 19.15v2.1M2.75 12h2.1M19.15 12h2.1M5.4 5.4l1.5 1.5M17.1 17.1l1.5 1.5M18.6 5.4l-1.5 1.5M6.9 17.1l-1.5 1.5"></path>
  </svg>
</button>

<style>
  .mm-theme-toggle {
    align-items: center;
    background: transparent;
    border: 0;
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    cursor: pointer;
    display: inline-flex;
    flex-shrink: 0;
    justify-content: center;
    padding: 0.45rem;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .mm-theme-toggle:hover {
    color: var(--color-action-primary);
  }

  .mm-theme-toggle:focus-visible {
    outline: 2px solid var(--mm-orange);
    outline-offset: 2px;
  }

  .mm-theme-toggle__icon {
    display: none;
  }

  :global(html:not([data-theme='dark'])) .mm-theme-toggle__icon--moon {
    display: block;
  }

  :global(html[data-theme='dark']) .mm-theme-toggle__icon--sun {
    display: block;
  }
</style>

<script>
  const STORAGE_KEY = 'mm-theme';

  function currentTheme() {
    return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
  }

  function applyTheme(theme: 'light' | 'dark') {
    document.documentElement.setAttribute('data-theme', theme);
    try {
      localStorage.setItem(STORAGE_KEY, theme);
    } catch {
      /* ignore private-mode storage failures */
    }

    const toggle = document.getElementById('mm-theme-toggle');
    if (!toggle) return;
    const next = theme === 'dark' ? 'light' : 'dark';
    toggle.setAttribute('aria-label', `Switch to ${next} mode`);
    toggle.setAttribute('title', `Switch to ${next} mode`);
  }

  document.getElementById('mm-theme-toggle')?.addEventListener('click', () => {
    applyTheme(currentTheme() === 'dark' ? 'light' : 'dark');
  });

  applyTheme(currentTheme());
</script>
