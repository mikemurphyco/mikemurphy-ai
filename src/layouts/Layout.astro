---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import { SITE_DESCRIPTION, SITE_TITLE, absoluteUrl } from '../lib/articles';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	image?: string;
	noHeader?: boolean;
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	canonical = Astro.url.pathname,
	image = '/assets/brand/og-default.png',
	noHeader = false,
} = Astro.props;

const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const canonicalUrl = canonical.startsWith('http') ? canonical : absoluteUrl(canonical);
const imageUrl = image.startsWith('http') ? image : absoluteUrl(image);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#001E3A" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:site_name" content={SITE_TITLE} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
	</head>
	<body class="antialiased">
		{!noHeader && <SiteHeader />}
		<slot />
		<footer class="border-t border-[var(--mm-navy)] bg-[var(--mm-navy)] text-[var(--mm-cream)]">
			<div class="mm-container grid gap-10 py-12 md:grid-cols-[1.35fr_0.8fr_0.8fr]">
				<div>
					<a href="/" class="flex items-center gap-3" aria-label="Mike Murphy home">
						<img src="/assets/brand/loop-orange-128.svg" alt="" class="size-11" />
						<span>
							<span class="block font-mono text-lg font-bold uppercase">Mike Murphy</span>
							<span class="block font-mono text-xs font-bold uppercase tracking-[0.16em] text-[var(--mm-orange)]">AI Handyman</span>
						</span>
					</a>
					<p class="mt-5 max-w-md text-sm leading-6 text-[color-mix(in_srgb,var(--mm-cream)_72%,transparent)]">
						Practical tutorials, AI workflows, and honest notes from the messy middle of learning in public.
					</p>
					<p class="mt-5 font-mono text-xs font-bold uppercase tracking-[0.14em]">
						Learn <span class="text-[var(--mm-orange)]">·</span> Build <span class="text-[var(--mm-orange)]">·</span> Move Forward
					</p>
				</div>
				<nav aria-label="Explore">
					<p class="font-mono text-xs font-bold uppercase tracking-[0.14em] text-[var(--mm-orange)]">Explore</p>
					<div class="mt-4 grid gap-3 text-sm font-semibold">
						<a href="/tutorials/" class="hover:text-[var(--mm-orange)]">Tutorials</a>
						<a href="/articles/" class="hover:text-[var(--mm-orange)]">Articles</a>
						<a href="/topics/" class="hover:text-[var(--mm-orange)]">Topics</a>
						<a href="/resources/" class="hover:text-[var(--mm-orange)]">Resources</a>
					</div>
				</nav>
				<nav aria-label="Connect">
					<p class="font-mono text-xs font-bold uppercase tracking-[0.14em] text-[var(--mm-orange)]">Connect</p>
					<div class="mt-4 grid gap-3 text-sm font-semibold">
						<a href="/ai-unplugged/" class="hover:text-[var(--mm-orange)]">AI Unplugged</a>
						<a href="/podcast/" class="hover:text-[var(--mm-orange)]">Podcast</a>
						<a href="/about/" class="hover:text-[var(--mm-orange)]">About Mike</a>
						<a href="/contact/" class="hover:text-[var(--mm-orange)]">Contact</a>
					</div>
				</nav>
			</div>
			<div class="border-t border-[color-mix(in_srgb,var(--mm-cream)_18%,transparent)]">
				<div class="mm-container flex flex-wrap items-center justify-between gap-3 py-5 font-mono text-[0.68rem] uppercase tracking-[0.1em] text-[color-mix(in_srgb,var(--mm-cream)_62%,transparent)]">
					<p>© {new Date().getFullYear()} Mike Murphy</p>
					<p>Built with Astro · Served by Cloudflare</p>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
