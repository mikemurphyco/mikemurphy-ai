---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import { SITE_DESCRIPTION, SITE_TITLE, absoluteUrl } from '../lib/articles';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	noHeader?: boolean;
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	canonical = Astro.url.pathname,
	noHeader = false,
} = Astro.props;

const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
const canonicalUrl = canonical.startsWith('http') ? canonical : absoluteUrl(canonical);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:type" content="website" />
	</head>
	<body class="antialiased">
		{!noHeader && <SiteHeader />}
		<slot />
		<footer class="border-t border-[var(--mm-border)] bg-[var(--mm-chalk)]">
			<div class="mm-container grid gap-8 py-10 md:grid-cols-[1fr_auto] md:items-start">
				<div>
					<a href="/" class="font-mono text-lg font-bold uppercase tracking-normal text-[var(--mm-navy)]">Mike Murphy</a>
					<p class="mt-3 max-w-xl text-sm leading-6 text-[var(--mm-muted)]">
						Practical tutorials, AI workflows, and honest notes from the messy middle of learning in public.
					</p>
				</div>
				<nav class="grid grid-cols-2 gap-x-8 gap-y-3 text-sm font-semibold md:text-right">
					<a href="/tutorials/" class="hover:underline">Tutorials</a>
					<a href="/ai-unplugged/" class="hover:underline">AI Unplugged</a>
					<a href="/articles/" class="hover:underline">Articles</a>
					<a href="/resources/" class="hover:underline">Resources</a>
					<a href="/podcast/" class="hover:underline">Podcast</a>
					<a href="/contact/" class="hover:underline">Contact</a>
				</nav>
			</div>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
