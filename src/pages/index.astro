---
import { getCollection } from 'astro:content';
import SubscribeBand from '../components/ai-unplugged/SubscribeBand.astro';
import TutorialCard from '../components/tutorials/TutorialCard.astro';
import Layout from '../layouts/Layout.astro';
import {
  SITE_DESCRIPTION,
  contentUrl,
  getTopicMap,
  isDiscoverableArticle,
  isPublishedIssue,
  isStandardArticle,
  sortArticlesByDate,
  sortIssuesByDate,
  sortTutorialsByDate,
} from '../lib/articles';

const allArticles = await getCollection('articles', isDiscoverableArticle);
const tutorials = sortTutorialsByDate(allArticles);
const latestTutorials = tutorials.slice(0, 4);
const latestArticles = sortArticlesByDate(allArticles.filter(isStandardArticle)).slice(0, 3);
const issues = sortIssuesByDate(await getCollection('aiUnplugged', isPublishedIssue));
const latestIssue = issues[0];
const topics = getTopicMap(tutorials).slice(0, 8);
const aiTutorials = tutorials.filter((tutorial) => tutorial.data.contentEra === 'ai').length;
---

<Layout title="AI Knowledge Hub" description={SITE_DESCRIPTION} canonical="/">
  <main>
    <section class="border-b border-[var(--mm-border)] bg-[var(--mm-cream)]">
      <div class="mm-container grid min-h-[calc(100svh-5rem)] gap-10 py-14 lg:grid-cols-[1.05fr_0.8fr] lg:items-center">
        <div>
          <p class="mm-eyebrow">mikemurphy.ai · tutorials, newsletter, and field notes</p>
          <h1 class="mm-display mt-5 max-w-5xl">AI Knowledge Hub</h1>
          <p class="mm-lede mt-6 max-w-3xl">
            A practical publication for learning AI tools, automation, and creative tech through clear tutorials, searchable notes, and weekly AI Unplugged issues.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/tutorials/" class="mm-button">Browse tutorials</a>
            <a href="/search/" class="mm-button mm-button-secondary">Search the archive</a>
            <a href="/ai-unplugged/" class="mm-button mm-button-secondary">Read AI Unplugged</a>
          </div>
          <dl class="mt-8 grid max-w-2xl grid-cols-3 gap-3">
            <div class="border-t border-[var(--mm-border)] pt-3">
              <dt class="mm-eyebrow">Tutorials</dt>
              <dd class="mt-1 font-mono text-3xl font-bold">{tutorials.length}</dd>
            </div>
            <div class="border-t border-[var(--mm-border)] pt-3">
              <dt class="mm-eyebrow">AI era</dt>
              <dd class="mt-1 font-mono text-3xl font-bold">{aiTutorials}</dd>
            </div>
            <div class="border-t border-[var(--mm-border)] pt-3">
              <dt class="mm-eyebrow">Issues</dt>
              <dd class="mt-1 font-mono text-3xl font-bold">{issues.length}</dd>
            </div>
          </dl>
          <div class="mt-8 flex flex-wrap gap-2">
            {topics.slice(0, 5).map((topic) => <a href={`/topics/${topic.slug}/`} class="mm-pill hover:border-[var(--mm-navy)]">{topic.name}</a>)}
          </div>
        </div>
        <div class="mx-auto w-full lg:justify-self-center">
          <div class="mm-polaroid rotate-2 lg:translate-x-10 xl:translate-x-12">
            <div class="mm-polaroid-photo">
              <img src="/assets/brand/avatar-mike-orange-1200.png" alt="Mike Murphy" />
            </div>
            <p>Mike</p>
          </div>
          <img src="/assets/brand/ai-handyman-badge.png" alt="AI Handyman" class="mx-auto mt-8 w-64 max-w-full" />
        </div>
      </div>
    </section>

    <section class="mm-container py-14">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="mm-eyebrow">Flagship</p>
          <h2 class="mm-h2 mt-2">Latest tutorials</h2>
        </div>
        <a href="/tutorials/" class="font-mono text-sm font-bold uppercase tracking-[0.1em] text-[var(--mm-orange-deep)] hover:underline">View all</a>
      </div>
      <div class="mt-8 grid gap-6 lg:grid-cols-3">
        {latestTutorials[0] && <div class="lg:col-span-2"><TutorialCard tutorial={latestTutorials[0]} featured /></div>}
        <div class="grid gap-6">
          {latestTutorials.slice(1, 3).map((tutorial) => <TutorialCard tutorial={tutorial} />)}
        </div>
      </div>
    </section>

    <SubscribeBand />

    <section class="mm-container grid gap-8 py-14 lg:grid-cols-[1fr_20rem]">
      <div>
        <p class="mm-eyebrow">Field notes</p>
        <h2 class="mm-h2 mt-2">Recent from the archive</h2>
        <div class="mt-6 grid gap-4">
          {latestArticles.map((article) => (
            <article class="border-b border-[var(--mm-border)] pb-4">
              <p class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-muted)]">
                {article.data.contentEra === 'ai' ? 'AI Era' : 'Archive'}
              </p>
              <h3 class="mt-2 text-xl font-bold leading-tight"><a href={contentUrl(article)} class="hover:underline">{article.data.title}</a></h3>
              {article.data.description && <p class="mt-2 text-sm leading-6 text-[var(--mm-muted)]">{article.data.description}</p>}
            </article>
          ))}
        </div>
      </div>
      <aside class="mm-card h-fit p-5">
        <p class="mm-eyebrow">Topics</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {topics.map((topic) => <a href={`/topics/${topic.slug}/`} class="mm-pill hover:border-[var(--mm-navy)]">{topic.name}</a>)}
        </div>
        {latestIssue && (
          <div class="mt-8 border-t border-[var(--mm-border)] pt-5">
            <p class="mm-eyebrow">Latest issue</p>
            <a href={`/ai-unplugged/issues/${latestIssue.data.slug}/`} class="mt-2 block font-mono text-lg font-bold uppercase leading-tight hover:underline">
              {latestIssue.data.subject}
            </a>
          </div>
        )}
      </aside>
    </section>
  </main>
</Layout>
