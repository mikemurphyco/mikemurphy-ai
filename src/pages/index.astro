---
import { getCollection } from 'astro:content';
import InlineSearch from '../components/InlineSearch.astro';
import SubscribeBand from '../components/ai-unplugged/SubscribeBand.astro';
import TutorialCard from '../components/tutorials/TutorialCard.astro';
import Layout from '../layouts/Layout.astro';
import {
  SITE_DESCRIPTION,
  getTopicMap,
  isDiscoverableArticle,
  isPublishedIssue,
  sortTutorialsByDate,
} from '../lib/articles';
import { fieldNoteUrl, isPublishedNote, noteTypeLabel, sortNotesByDate } from '../lib/field-notes';

const allArticles = await getCollection('articles', isDiscoverableArticle);
// Two freshest Field Notes greet visitors above the footer; rotates as new
// notes publish (date-sorted, not the `featured` pins from the index page).
const freshNotes = sortNotesByDate(await getCollection('fieldNotes', isPublishedNote)).slice(0, 2);
const tutorials = sortTutorialsByDate(allArticles);
const latestTutorials = tutorials.slice(0, 6);
const issues = await getCollection('aiUnplugged', isPublishedIssue);
const topics = getTopicMap(tutorials).slice(0, 8);
const aiTutorials = tutorials.filter((tutorial) => tutorial.data.contentEra === 'ai').length;
---

<Layout title="AI Knowledge Hub" description={SITE_DESCRIPTION} canonical="/">
  <main>
    <section class="border-b border-[var(--mm-border)] bg-[var(--color-bg-page)]">
      <div class="mm-container py-14">
        {/* Design-system hero row: copy + CTAs | art. Stats/topics sit below so
            items-center isn't measuring against the taller meta block. */}
        <div class="grid gap-10 lg:grid-cols-[1.05fr_0.8fr] lg:items-center">
          <div>
            <p class="mm-eyebrow">mikemurphy.ai · tutorials, newsletter, and field notes</p>
            <h1 class="mm-display mt-5 max-w-5xl">AI Knowledge Hub</h1>
            <p class="mm-lede mt-6 max-w-3xl">
              A practical publication for learning AI tools, automation, and creative tech through clear tutorials, searchable notes, and weekly AI Unplugged issues.
            </p>
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="/tutorials/" class="mm-button">Browse tutorials</a>
              <a href="/search/" class="mm-button mm-button-secondary">Search the archive</a>
              <a href="/ai-unplugged/" class="mm-button mm-button-secondary">Read AI Unplugged</a>
            </div>
          </div>
          <div class="mx-auto flex w-full justify-center lg:justify-self-center">
            <div class="flex w-[min(100%,248px)] flex-col items-center">
              <div class="mm-polaroid rotate-2">
                <div class="mm-polaroid-photo">
                  <img src="/assets/brand/avatar-mike-orange-1200.png" alt="Mike Murphy" />
                </div>
                <p>Mike</p>
              </div>
              <p class="mm-badge-ai-handyman mt-8">AI Handyman</p>
            </div>
          </div>
        </div>
        <dl class="mt-10 grid max-w-2xl grid-cols-3 gap-3">
          <div class="border-t border-[var(--mm-border)] pt-3">
            <dt class="mm-eyebrow">Tutorials</dt>
            <dd class="mt-1 font-mono text-3xl font-bold">{tutorials.length}</dd>
          </div>
          <div class="border-t border-[var(--mm-border)] pt-3">
            <dt class="mm-eyebrow">AI era</dt>
            <dd class="mt-1 font-mono text-3xl font-bold">{aiTutorials}</dd>
          </div>
          <div class="border-t border-[var(--mm-border)] pt-3">
            <dt class="mm-eyebrow">Issues</dt>
            <dd class="mt-1 font-mono text-3xl font-bold">{issues.length}</dd>
          </div>
        </dl>
        <div class="mt-8 flex flex-wrap gap-2">
          {topics.slice(0, 5).map((topic) => <a href={`/topics/${topic.slug}/`} class="mm-pill hover:border-[var(--color-border-strong)]">{topic.name}</a>)}
        </div>
      </div>
    </section>

    <section class="border-b border-[var(--mm-border)]">
      <div class="mm-container py-8">
        <InlineSearch label="Search the hub" placeholder="Search tutorials, articles, episodes, and issues…" />
      </div>
    </section>

    <section class="mm-container py-14" data-inline-search-hide>
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="mm-eyebrow">Flagship</p>
          <h2 class="mm-h2 mt-2">Latest tutorials</h2>
        </div>
        <a href="/tutorials/" class="font-mono text-sm font-bold uppercase tracking-[0.1em] text-[var(--mm-orange-deep)] hover:underline">View all</a>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {latestTutorials.map((tutorial) => <TutorialCard tutorial={tutorial} />)}
      </div>
    </section>

    <div data-inline-search-hide>
      <SubscribeBand />
    </div>

    {freshNotes.length > 0 && (
      <section class="border-t border-[var(--mm-border)]" data-inline-search-hide>
        <div class="mm-container py-14">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <p class="mm-eyebrow">Field notes</p>
              <h2 class="mm-h2 mt-2">Fresh tips before you go</h2>
            </div>
            <a href="/field-notes/" class="font-mono text-sm font-bold uppercase tracking-[0.1em] text-[var(--mm-orange-deep)] hover:underline">All field notes</a>
          </div>
          <div class="mt-8 grid gap-5 md:grid-cols-2">
            {freshNotes.map((note) => (
              <a href={fieldNoteUrl(note)} class="mm-card group flex flex-col p-6 transition hover:border-[var(--color-border-strong)]">
                {note.data.noteType && (
                  <span class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange-deep)]">
                    {noteTypeLabel(note.data.noteType)}
                  </span>
                )}
                <h3 class="mt-3 font-mono text-2xl font-bold uppercase leading-tight group-hover:underline">
                  {note.data.title}
                </h3>
                {note.data.excerpt && (
                  <p class="mt-3 text-base leading-7 text-[var(--mm-muted)]">{note.data.excerpt}</p>
                )}
                <span class="mt-4 font-mono text-sm font-bold uppercase tracking-[0.1em] text-[var(--mm-orange-deep)]">
                  Read note -&gt;
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>
