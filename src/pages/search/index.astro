---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Search"
  description="Full-text search across tutorials, articles, podcast episodes, and AI Unplugged issues."
  canonical="/search/"
>
  <main class="mm-container max-w-4xl py-12">
    <header>
      <p class="mm-eyebrow">Search</p>
      <h1 class="mm-h1 mt-3">Search the archive</h1>
      <p class="mm-lede mt-4 max-w-2xl">
        Full-text search across tutorials, articles, podcast episodes, and AI Unplugged issues. Filter by type to narrow it down.
      </p>
    </header>

    <div id="search" class="mt-8"></div>
  </main>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        pageSize: 10,
      });
    });
  </script>
</Layout>

<style is:global>
  /* Pagefind UI mapped onto the mm token system. Global because
     Pagefind injects its DOM at runtime, outside Astro's scoping. */
  #search {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--mm-navy);
    --pagefind-ui-text: var(--color-text-primary);
    --pagefind-ui-background: var(--mm-chalk);
    --pagefind-ui-border: var(--color-border-strong);
    --pagefind-ui-tag: var(--mm-cream);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-md);
    --pagefind-ui-font: var(--font-sans);
  }

  #search .pagefind-ui__search-input {
    background: var(--mm-cream);
    box-shadow: 2px 2px 0 var(--color-shadow-ink);
    font-weight: 400;
  }

  #search .pagefind-ui__search-input:focus-visible {
    outline: 2px solid var(--mm-orange);
    outline-offset: 2px;
  }

  #search .pagefind-ui__search-clear {
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    font-weight: 700;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }

  #search .pagefind-ui__message,
  #search .pagefind-ui__filter-name,
  #search .pagefind-ui__filter-value {
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }

  #search .pagefind-ui__filter-value {
    font-weight: 400;
  }

  #search .pagefind-ui__result {
    border-top: 1px solid var(--color-border-default);
    padding-block: var(--space-6);
  }

  #search .pagefind-ui__result-title .pagefind-ui__result-link {
    color: var(--color-text-primary);
    font-weight: 700;
  }

  #search .pagefind-ui__result-title .pagefind-ui__result-link:hover {
    color: var(--mm-orange-deep);
  }

  #search .pagefind-ui__result-excerpt {
    color: var(--color-text-muted);
  }

  #search .pagefind-ui__result-excerpt mark {
    background: var(--mm-yellow);
    color: var(--mm-navy);
  }

  #search .pagefind-ui__button {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-strong);
    box-shadow: var(--shadow-cut);
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }

  #search .pagefind-ui__button:hover {
    background: var(--mm-cream);
  }
</style>
