---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getTopicMap, isDiscoverableArticle, sortArticlesByDate } from '../../lib/articles';

export async function getStaticPaths() {
  const articles = sortArticlesByDate(await getCollection('articles', isDiscoverableArticle));
  const topics = getTopicMap(articles);

  return topics.map((topic) => ({
    params: { topic: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
---

<Layout
  title={topic.name}
  description={`Browse ${topic.articles.length} Mike Murphy articles about ${topic.name}.`}
  canonical={`/topics/${topic.slug}/`}
>
  <main class="mm-container max-w-5xl py-12">
    <header class="border-b border-[var(--mm-border)] pb-8">
      <a href="/topics/" class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange-deep)] hover:underline">All topics</a>
      <h1 class="mm-h1 mt-4">{topic.name}</h1>
      <p class="mm-lede mt-4">{topic.articles.length} articles</p>
    </header>

    <section class="mt-4">
      {topic.articles.map((article) => <ArticleCard article={article} />)}
    </section>
  </main>
</Layout>
