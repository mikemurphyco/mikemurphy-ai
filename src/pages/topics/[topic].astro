---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getTopicMap, isDiscoverableArticle, sortArticlesByDate } from '../../lib/articles';

export async function getStaticPaths() {
  const articles = sortArticlesByDate(await getCollection('articles', isDiscoverableArticle));
  const topics = getTopicMap(articles);

  return topics.map((topic) => ({
    params: { topic: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
---

<Layout
  title={topic.name}
  description={`Browse ${topic.articles.length} Mike Murphy articles about ${topic.name}.`}
  canonical={`/topics/${topic.slug}/`}
>
  <main class="mx-auto max-w-5xl px-6 py-12">
    <header class="border-b border-slate-200 pb-8">
      <a href="/topics/" class="text-sm font-semibold text-slate-600 hover:text-slate-950">All topics</a>
      <h1 class="mt-4 text-4xl font-bold text-slate-950">{topic.name}</h1>
      <p class="mt-3 text-lg text-slate-600">{topic.articles.length} articles</p>
    </header>

    <section class="mt-4">
      {topic.articles.map((article) => <ArticleCard article={article} />)}
    </section>
  </main>
</Layout>
