---
import { getCollection } from 'astro:content';
import IssueCard from '../../../components/ai-unplugged/IssueCard.astro';
import InlineSearch from '../../../components/InlineSearch.astro';
import Layout from '../../../layouts/Layout.astro';
import { isPublishedIssue, sortIssuesByDate } from '../../../lib/articles';

const issues = sortIssuesByDate(await getCollection('aiUnplugged', isPublishedIssue));
---

<Layout title="AI Unplugged Issues" description="Browse the AI Unplugged issue archive." canonical="/ai-unplugged/issues/">
  <main class="mm-container py-12">
    <a href="/ai-unplugged/" class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange-deep)] hover:underline">Back to AI Unplugged</a>
    <header class="mt-5 border-b border-[var(--mm-border)] pb-8">
      <p class="mm-eyebrow">AI Unplugged · all issues</p>
      <h1 class="mm-h1 mt-3">Issue archive</h1>
      <p class="mm-lede mt-5 max-w-3xl">
        Native Astro pages for every issue, with Beehiiv as the sender and source tracker.
      </p>
      <p class="mt-5 flex flex-wrap gap-4">
        <a href="/ai-unplugged/rss.xml" class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange)] hover:text-[var(--mm-orange-deep)]">
          RSS feed →
        </a>
        <a href="/ai-unplugged/agent.json" class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange)] hover:text-[var(--mm-orange-deep)]">
          Agent JSON →
        </a>
      </p>
    </header>
    <div class="mt-8">
      <InlineSearch filterType="Issue" label="Search issues" placeholder={`Search ${issues.length} issues…`} />
    </div>
    <section class="mt-8 grid gap-5" data-inline-search-hide>
      {issues.map((issue) => <IssueCard issue={issue} />)}
    </section>
  </main>
</Layout>
