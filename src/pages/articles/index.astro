---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getTopicMap, isDiscoverableArticle, sortArticlesByDate } from '../../lib/articles';

const articles = await getCollection('articles', isDiscoverableArticle);
const sorted = sortArticlesByDate(articles);
const topics = getTopicMap(sorted).slice(0, 10);

const aiCount = sorted.filter((article) => article.data.contentEra === 'ai').length;
const archiveCount = sorted.filter((article) => article.data.contentEra === 'legacy').length;
---

<Layout title="Articles" description="Browse the full Mike Murphy archive of AI, automation, creative tech, podcasting, and media production tutorials." canonical="/articles/">
  <main class="mx-auto max-w-6xl px-6 py-12">
    <header class="border-b border-slate-200 pb-8">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Archive</p>
      <div class="mt-3 grid gap-6 lg:grid-cols-[1fr_20rem] lg:items-end">
        <div>
          <h1 class="text-4xl font-bold text-slate-950">Articles</h1>
          <p class="mt-3 max-w-2xl text-lg leading-8 text-slate-600">
            The full searchable corpus: current AI work, creative software tutorials, podcast episodes,
            production workflows, and the legacy archive.
          </p>
        </div>
        <dl class="grid grid-cols-3 gap-3 text-center">
          <div class="rounded-md border border-slate-200 bg-white p-4">
            <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Total</dt>
            <dd class="mt-1 text-2xl font-bold text-slate-950">{sorted.length}</dd>
          </div>
          <div class="rounded-md border border-slate-200 bg-white p-4">
            <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">AI</dt>
            <dd class="mt-1 text-2xl font-bold text-slate-950">{aiCount}</dd>
          </div>
          <div class="rounded-md border border-slate-200 bg-white p-4">
            <dt class="text-xs font-medium uppercase tracking-wide text-slate-500">Archive</dt>
            <dd class="mt-1 text-2xl font-bold text-slate-950">{archiveCount}</dd>
          </div>
        </dl>
      </div>
      <div class="mt-8 flex flex-wrap gap-2">
        {topics.map((topic) => (
          <a href={`/topics/${topic.slug}/`} class="rounded-full bg-white px-3 py-2 text-sm font-medium text-slate-700 ring-1 ring-slate-200 hover:ring-slate-400">
            {topic.name}
          </a>
        ))}
      </div>
    </header>

    <section class="mt-4">
      {sorted.map((article) => <ArticleCard article={article} />)}
    </section>
  </main>
</Layout>
