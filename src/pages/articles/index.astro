---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/ArticleCard.astro';
import InlineSearch from '../../components/InlineSearch.astro';
import Layout from '../../layouts/Layout.astro';
import { getTopicMap, isDiscoverableArticle, isStandardArticle, sortArticlesByDate } from '../../lib/articles';

const articles = await getCollection('articles', (article) => isDiscoverableArticle(article) && isStandardArticle(article));
const sorted = sortArticlesByDate(articles);
const topics = getTopicMap(sorted).slice(0, 10);

const aiCount = sorted.filter((article) => article.data.contentEra === 'ai').length;
const archiveCount = sorted.filter((article) => article.data.contentEra === 'legacy').length;
---

<Layout title="Articles" description="Browse Mike Murphy articles, essays, notes, and legacy posts that are not tutorials or podcast episodes." canonical="/articles/">
  <main class="mm-container py-12">
    <header class="border-b border-[var(--mm-border)] pb-8">
      <div class="grid gap-8 lg:grid-cols-[1fr_24rem] lg:items-end">
        <div>
          <p class="mm-eyebrow">Archive</p>
          <h1 class="mm-h1 mt-3">Articles</h1>
          <p class="mm-lede mt-5 max-w-3xl">
            Blog posts, practical notes, essays, and legacy articles. Tutorials and podcast episodes now have their own lanes.
          </p>
        </div>
        <dl class="mm-card grid grid-cols-3 gap-0 overflow-hidden text-center">
          <div class="border-r border-[var(--mm-border)] p-5">
            <dt class="mm-eyebrow">Total</dt>
            <dd class="mt-2 text-4xl font-bold">{sorted.length}</dd>
          </div>
          <div class="border-r border-[var(--mm-border)] p-5">
            <dt class="mm-eyebrow">AI</dt>
            <dd class="mt-2 text-4xl font-bold">{aiCount}</dd>
          </div>
          <div class="p-5">
            <dt class="mm-eyebrow">Archive</dt>
            <dd class="mt-2 text-4xl font-bold">{archiveCount}</dd>
          </div>
        </dl>
      </div>
      <div class="mt-8 flex flex-wrap gap-2">
        {topics.map((topic) => (
          <a href={`/topics/${topic.slug}/`} class="mm-pill hover:border-[var(--mm-navy)]">{topic.name}</a>
        ))}
      </div>
    </header>

    <div class="mt-8">
      <InlineSearch filterType="Article" label="Search articles" placeholder={`Search ${sorted.length} articles…`} />
    </div>

    <section class="mt-4" data-inline-search-hide>
      {sorted.map((article) => <ArticleCard article={article} />)}
    </section>
  </main>
</Layout>
