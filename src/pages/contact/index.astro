---
import Layout from '../../layouts/Layout.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import { mailtoHref } from '../../lib/site';

const intents = [
  {
    title: 'Just say hi',
    description: 'Send a short note, tutorial question, or useful correction.',
    href: mailtoHref(),
    cta: 'Email Mike',
    external: false,
  },
  {
    title: 'Work with me',
    description: 'AI workflows, creator systems, automation, and practical implementation help.',
    href: mailtoHref('Work with me'),
    cta: 'Start a conversation',
    external: false,
  },
  {
    title: 'Follow along',
    description: 'Subscribe to AI Unplugged and get to know the work through the writing.',
    href: '/ai-unplugged/',
    cta: 'AI Unplugged',
    external: false,
  },
] as const;
---

<Layout title="Contact" description="Contact Mike Murphy for questions, consulting, sponsorships, and replies." canonical="/contact/">
  <main class="mm-container py-12">
    <p class="mm-eyebrow">Contact</p>
    <h1 class="mm-h1 mt-3">A few good ways to reach me.</h1>
    <p class="mm-lede mt-5 max-w-3xl">
      Questions, consulting, sponsorships, and thoughtful replies all belong here.
    </p>
    <section class="mt-10 grid gap-5 md:grid-cols-3">
      {
        intents.map((item) => (
          <article class="mm-card flex flex-col p-5">
            <h2 class="font-mono text-xl font-bold uppercase tracking-normal">{item.title}</h2>
            <p class="mt-3 flex-1 text-sm leading-6 text-[var(--mm-muted)]">{item.description}</p>
            <a href={item.href} class="mt-5 inline-flex font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange)] hover:text-[var(--mm-orange-deep)]">
              {item.cta} →
            </a>
          </article>
        ))
      }
    </section>
    <div class="mt-8 flex flex-wrap gap-4">
      <a href={mailtoHref()} class="mm-button">Email Mike</a>
      <a href="/ai-unplugged/" class="mm-button mm-button-secondary">AI Unplugged</a>
    </div>
    <div class="mt-12">
      <p class="font-mono text-xs font-bold uppercase tracking-[0.14em] text-[var(--mm-orange)]">Find me elsewhere</p>
      <SocialLinks class="mt-4" />
    </div>
  </main>
</Layout>
