---
import Layout from '../../layouts/Layout.astro';

const resources = [
  {
    name: 'Astro',
    mark: 'As',
    group: 'Builder Stack',
    cost: 'Free',
    relationship: 'Used Here',
    color: 'bg-[var(--mm-yellow)]',
    url: 'https://astro.build/',
    tags: ['Framework', 'Static Site'],
    description:
      'The framework behind mikemurphy.ai. I use it for fast pages, Markdown content collections, clean routes, and a site that feels easier to maintain than WordPress for this AI-builder hub.',
  },
  {
    name: 'Cloudflare Domains',
    mark: 'Cd',
    group: 'Builder Stack',
    cost: 'Paid',
    relationship: 'Used Here',
    color: 'bg-[var(--mm-orange)] text-[var(--mm-navy)]',
    url: 'https://www.cloudflare.com/products/registrar/',
    tags: ['Domains', 'DNS'],
    description:
      'Where I manage DNS for the new site. It keeps the domain, DNS records, redirects, and Cloudflare services close together, which makes launch plumbing less scattered.',
  },
  {
    name: 'Cloudflare Pages',
    mark: 'Cp',
    group: 'Builder Stack',
    cost: 'Free + Paid',
    relationship: 'Used Here',
    color: 'bg-[var(--mm-orange)] text-[var(--mm-navy)]',
    url: 'https://pages.cloudflare.com/',
    tags: ['Hosting', 'Deploys'],
    description:
      'The hosting layer for mikemurphy.ai. GitHub main deploys to Cloudflare Pages, so publishing is mostly edit, build, commit, push, and verify.',
  },
  {
    name: 'GitHub',
    mark: 'Gh',
    group: 'Builder Stack',
    cost: 'Free + Paid',
    relationship: 'Used Here',
    color: 'bg-[var(--mm-chalk)]',
    url: 'https://github.com/',
    tags: ['Codebase', 'Version Control'],
    description:
      'The source of truth for the Astro codebase. It gives me history, rollback confidence, pull-request workflows, and the deploy trigger for Cloudflare.',
  },
  {
    name: 'Hostinger VPS',
    mark: 'Hv',
    group: 'Infrastructure',
    cost: 'Paid',
    relationship: 'Affiliate',
    color: 'bg-[var(--mm-navy)] text-[var(--mm-cream)]',
    url: 'https://mikemurphy.co/vps',
    tags: ['VPS', 'Self-Hosting'],
    description:
      'My practical VPS choice for tutorials around n8n, Docker, Traefik, SSH, firewalls, and self-hosted AI workflows. It is the server playground behind a lot of the newer tutorials.',
  },
  {
    name: 'Shlink',
    mark: 'Sh',
    group: 'Infrastructure',
    cost: 'Free',
    relationship: 'Planned',
    color: 'bg-[var(--mm-teal)]',
    url: 'https://shlink.io/',
    tags: ['Short Links', 'Analytics'],
    description:
      'The planned short-link system for go.mikemurphy.co. The goal is cleaner resource links, better campaign tracking, and less dependence on older Pretty Links.',
  },
  {
    name: 'OpenAI Codex',
    mark: 'Cx',
    group: 'AI Workbench',
    cost: 'Paid',
    relationship: 'Used Here',
    color: 'bg-[var(--mm-navy)] text-[var(--mm-cream)]',
    url: 'https://openai.com/codex/',
    tags: ['CLI', 'Code'],
    description:
      'My terminal-native coding partner for real project edits, migration cleanup, QA loops, and launch checklists. Good when I want the work to happen inside the repo.',
  },
  {
    name: 'Claude Code',
    mark: 'Cl',
    group: 'AI Workbench',
    cost: 'Paid',
    relationship: 'Used Daily',
    color: 'bg-[var(--mm-orange)] text-[var(--mm-navy)]',
    url: 'https://www.anthropic.com/claude-code',
    tags: ['CLI', 'Writing + Code'],
    description:
      'A daily driver for code, writing drafts, research loops, and thinking through build decisions. It is one of the tools that changed how I work with notes and projects.',
  },
  {
    name: 'Obsidian',
    mark: 'Ob',
    group: 'AI Workbench',
    cost: 'Free + Paid',
    relationship: 'Used Daily',
    color: 'bg-[var(--mm-teal)]',
    url: 'https://obsidian.md/',
    tags: ['Notes', 'Knowledge Base'],
    description:
      'My drafting and thinking space. Obsidian is where tutorial ideas, newsletter notes, commands, research, and reusable working context start before they become publishable Astro content.',
  },
  {
    name: 'n8n',
    mark: 'n8',
    group: 'AI Workbench',
    cost: 'Free + Paid',
    relationship: 'Used Often',
    color: 'bg-[var(--mm-yellow)]',
    url: 'https://n8n.io/',
    tags: ['Automation', 'Workflows'],
    description:
      'The automation workbench I use and teach for connecting AI tools, APIs, notifications, forms, databases, and self-hosted services without turning every idea into a custom app.',
  },
  {
    name: 'ElevenLabs',
    mark: 'El',
    group: 'Content Stack',
    cost: 'Free + Paid',
    relationship: 'Affiliate',
    color: 'bg-[var(--mm-orange)] text-[var(--mm-navy)]',
    url: 'https://mikemurphy.co/elevenlabs',
    tags: ['Voice', 'Audio'],
    description:
      'The AI audio tool I use for voice experiments, text-to-speech, sound effects, and music tutorials. It belongs here because it is part of the practical creator-AI toolkit.',
  },
  {
    name: 'Beehiiv',
    mark: 'Bv',
    group: 'Content Stack',
    cost: 'Free + Paid',
    relationship: 'Used Here',
    color: 'bg-[var(--mm-chalk)]',
    url: 'https://www.beehiiv.com/',
    tags: ['Newsletter', 'Publishing'],
    description:
      'The sending engine for AI Unplugged. Astro owns the public archive, while Beehiiv handles subscribers, email delivery, and the newsletter side of the operation.',
  },
];

const groups = ['Builder Stack', 'Infrastructure', 'AI Workbench', 'Content Stack'];
const availableFilters = ['All', ...groups];
const totalResources = resources.length;
const affiliateCount = resources.filter((resource) => resource.relationship === 'Affiliate').length;
---

<Layout
  title="Resources"
  description="The tools, services, and AI-builder stack Mike Murphy actually uses to build mikemurphy.ai, tutorials, automations, and creator workflows."
  canonical="/resources/"
>
  <main>
    <section class="border-b border-[var(--mm-border)]">
      <div class="mm-container grid gap-8 py-12 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
        <div>
          <p class="mm-eyebrow">Resources</p>
          <h1 class="mm-h1 mt-3">Tools I Actually Use</h1>
          <p class="mm-lede mt-5 max-w-3xl">
            A field guide to the software, services, and infrastructure behind mikemurphy.ai, AI Unplugged, and the tutorials I am building in public.
          </p>
        </div>
        <aside class="mm-card p-5">
          <p class="mm-eyebrow">Affiliate note</p>
          <p class="mt-3 text-sm leading-6 text-[var(--mm-muted)]">
            Some links on this page are affiliate links. If you buy through one, I may earn a commission at no extra cost to you. I only list tools I use, have used, or genuinely recommend.
          </p>
        </aside>
      </div>
    </section>

    <section class="mm-container py-10">
      <div class="grid gap-4 md:grid-cols-3">
        <div class="border-t border-[var(--mm-border)] pt-4">
          <p class="mm-eyebrow">Current shelf</p>
          <p class="mt-2 font-mono text-3xl font-bold">{totalResources}</p>
        </div>
        <div class="border-t border-[var(--mm-border)] pt-4">
          <p class="mm-eyebrow">Affiliate links</p>
          <p class="mt-2 font-mono text-3xl font-bold">{affiliateCount}</p>
        </div>
        <div class="border-t border-[var(--mm-border)] pt-4">
          <p class="mm-eyebrow">Focus</p>
          <p class="mt-2 font-mono text-3xl font-bold">AI Builder</p>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-3" aria-label="Resource filters">
        {availableFilters.map((filter) => (
          <button
            class:list={[
              'mm-pill px-4 py-2',
              filter === 'All' && 'border-[var(--mm-navy)] bg-[var(--mm-navy)] text-[var(--mm-cream)]',
            ]}
            type="button"
            data-resource-filter={filter.toLowerCase()}
          >
            {filter}
          </button>
        ))}
      </div>
    </section>

    <section class="mm-container space-y-14 pb-14">
      {groups.map((group) => {
        const groupResources = resources.filter((resource) => resource.group === group);

        return (
          <section data-resource-group={group.toLowerCase()}>
            <div class="mb-6 flex flex-wrap items-end justify-between gap-3 border-b border-[var(--mm-navy)] pb-3">
              <div>
                <h2 class="mm-h2">{group}</h2>
                <p class="mt-3 max-w-3xl text-lg leading-8 text-[var(--mm-muted)]">
                  {group === 'Builder Stack' && 'The visible and invisible pieces used to build, ship, and maintain this Astro site.'}
                  {group === 'Infrastructure' && 'Servers, short links, and self-hosted pieces that support tutorials and practical AI workflows.'}
                  {group === 'AI Workbench' && 'The AI coding, notes, and automation tools that stay open while I build and teach.'}
                  {group === 'Content Stack' && 'Publishing, audio, and newsletter tools that help turn experiments into useful resources.'}
                </p>
              </div>
              <p class="font-mono text-sm font-bold uppercase tracking-[0.16em] text-[var(--mm-muted)]">
                {groupResources.length} items
              </p>
            </div>

            <div class="grid gap-5">
              {groupResources.map((resource) => (
                <article class="mm-resource-row" data-resource-type={resource.group.toLowerCase()}>
                  <span class:list={['mm-resource-mark', resource.color]}>{resource.mark}</span>
                  <div class="min-w-0">
                    <div class="flex flex-wrap gap-2">
                      <span class="mm-pill">{resource.cost}</span>
                      <span class:list={['mm-pill', resource.relationship === 'Affiliate' && 'border-[var(--mm-orange)]']}>
                        {resource.relationship}
                      </span>
                      {resource.tags.map((tag) => <span class="mm-pill">{tag}</span>)}
                    </div>
                    <h3 class="mt-3 font-mono text-2xl font-bold uppercase leading-tight">{resource.name}</h3>
                    <p class="mt-2 max-w-3xl text-lg leading-7 text-[var(--mm-muted)]">{resource.description}</p>
                  </div>
                  <a href={resource.url} class="font-mono text-sm font-bold uppercase tracking-[0.1em] text-[var(--mm-orange-deep)] hover:underline">
                    Visit ->
                  </a>
                </article>
              ))}
            </div>
          </section>
        );
      })}

      <section class="grid gap-5 border-t border-[var(--mm-border)] pt-10 md:grid-cols-2">
        <article class="mm-card p-5">
          <p class="mm-eyebrow">Future shelf</p>
          <h2 class="mt-3 font-mono text-2xl font-bold uppercase leading-tight">Books belong nearby, not mixed in.</h2>
          <p class="mt-3 text-sm leading-6 text-[var(--mm-muted)]">
            A separate books page makes sense for reading lists, reference shelves, and ideas that shape how I build and teach without turning this page into a general personal library.
          </p>
        </article>
        <article class="mm-card p-5">
          <p class="mm-eyebrow">Future shelf</p>
          <h2 class="mt-3 font-mono text-2xl font-bold uppercase leading-tight">Favorite things can be its own side quest.</h2>
          <p class="mt-3 text-sm leading-6 text-[var(--mm-muted)]">
            Gear, pens, notebooks, health tools, and studio odds and ends are useful, but they should live on a separate page when they are ready so the main Resources page stays AI-builder focused.
          </p>
        </article>
      </section>
    </section>
  </main>

  <script>
    const buttons = document.querySelectorAll('[data-resource-filter]');
    const groups = document.querySelectorAll('[data-resource-group]');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const filter = button.getAttribute('data-resource-filter');

        buttons.forEach((item) => {
          item.classList.toggle('bg-[var(--mm-navy)]', item === button);
          item.classList.toggle('text-[var(--mm-cream)]', item === button);
          item.classList.toggle('border-[var(--mm-navy)]', item === button);
        });

        groups.forEach((group) => {
          const show = filter === 'all' || group.getAttribute('data-resource-group') === filter;
          group.toggleAttribute('hidden', !show);
        });
      });
    });
  </script>
</Layout>
