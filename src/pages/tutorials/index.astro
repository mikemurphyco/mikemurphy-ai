---
import { getCollection } from 'astro:content';
import InlineSearch from '../../components/InlineSearch.astro';
import SubscribeBand from '../../components/ai-unplugged/SubscribeBand.astro';
import TutorialCard from '../../components/tutorials/TutorialCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getTopicMap, isDiscoverableArticle, sortTutorialsByDate } from '../../lib/articles';

const allArticles = await getCollection('articles', isDiscoverableArticle);
const tutorials = sortTutorialsByDate(allArticles);
const topics = getTopicMap(tutorials).slice(0, 12);
const aiTutorials = tutorials.filter((tutorial) => tutorial.data.contentEra === 'ai').length;
---

<Layout title="Tutorials" description="Practical AI, automation, and creative tech tutorials by Mike Murphy." canonical="/tutorials/">
  <main>
    <section class="border-b border-[var(--mm-border)]">
      <div class="mm-container grid gap-8 py-12 lg:grid-cols-[1fr_20rem] lg:items-end">
        <div>
          <p class="mm-eyebrow">Flagship</p>
          <h1 class="mm-h1 mt-3">Tutorials</h1>
          <p class="mm-lede mt-5 max-w-3xl">
            Step-by-step lessons for AI tools, automation systems, After Effects, podcasting, and the creative production stack.
          </p>
          <p class="mt-5">
            <a href="/tutorials/rss.xml" class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange)] hover:text-[var(--mm-orange-deep)]">
              RSS feed →
            </a>
          </p>
        </div>
        <dl class="mm-card grid grid-cols-2 gap-0 overflow-hidden text-center">
          <div class="border-r border-[var(--mm-border)] p-5">
            <dt class="mm-eyebrow">Total</dt>
            <dd class="mt-2 text-4xl font-bold">{tutorials.length}</dd>
          </div>
          <div class="p-5">
            <dt class="mm-eyebrow">AI era</dt>
            <dd class="mt-2 text-4xl font-bold">{aiTutorials}</dd>
          </div>
        </dl>
      </div>
    </section>

    <section class="mm-container py-10">
      <InlineSearch filterType="Tutorial" label="Search tutorials" placeholder={`Search ${tutorials.length} tutorials…`} />
      <div data-inline-search-hide class="mt-8">
        <div class="flex flex-wrap gap-2">
          {topics.map((topic) => <a href={`/topics/${topic.slug}/`} class="mm-pill hover:border-[var(--color-border-strong)]">{topic.name}</a>)}
        </div>
        <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {tutorials.map((tutorial) => <TutorialCard tutorial={tutorial} />)}
        </div>
      </div>
    </section>

    <SubscribeBand compact />
  </main>
</Layout>
