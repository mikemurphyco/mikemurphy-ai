---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { fieldNoteUrl, isPublishedNote, noteTypeLabel, sortNotesByDate } from '../../lib/field-notes';

const allNotes = sortNotesByDate(await getCollection('fieldNotes', isPublishedNote));

// Two featured boxes at the top; fall back to the two most recent if fewer than
// two notes are explicitly featured, so the layout is never half-empty.
const featured = allNotes.filter((note) => note.data.featured);
const featuredBoxes = (featured.length >= 2 ? featured : allNotes).slice(0, 2);

function formatDate(value: Date | null): string {
  if (!value) return '';
  return new Date(value).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<Layout
  title="Field Notes"
  description="Quick tips, shortcuts, snippets, and small nuggets from Mike Murphy — bite-sized field notes on AI, automation, the terminal, and building in public."
  canonical="/field-notes/"
>
  <main>
    <section class="border-b border-[var(--mm-border)]">
      <div class="mm-container py-12">
        <p class="mm-eyebrow">Field notes</p>
        <h1 class="mm-h1 mt-3">Quick Tips, Snippets & Nuggets</h1>
        <p class="mm-lede mt-5 max-w-3xl">
          Small, practical things worth writing down — shortcuts, gotchas, definitions, and snippets from the day-to-day of building with AI and automation. Bite-sized, and each one opens to its own page.
        </p>
      </div>
    </section>

    {featuredBoxes.length > 0 && (
      <section class="mm-container py-10">
        <p class="mm-eyebrow">Featured</p>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {featuredBoxes.map((note) => (
            <a href={fieldNoteUrl(note)} class="mm-card group flex flex-col p-6 transition hover:border-[var(--color-border-strong)]">
              {note.data.noteType && (
                <span class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange-deep)]">
                  {noteTypeLabel(note.data.noteType)}
                </span>
              )}
              <h2 class="mt-3 font-mono text-2xl font-bold uppercase leading-tight group-hover:underline">
                {note.data.title}
              </h2>
              {note.data.excerpt && (
                <p class="mt-3 text-base leading-7 text-[var(--mm-muted)]">{note.data.excerpt}</p>
              )}
              <span class="mt-4 font-mono text-sm font-bold uppercase tracking-[0.1em] text-[var(--mm-orange-deep)]">
                Read note -&gt;
              </span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mm-container pb-16">
      <div class="mb-6 flex flex-wrap items-end justify-between gap-3 border-b border-[var(--color-border-strong)] pb-3">
        <h2 class="mm-h2">All Field Notes</h2>
        <p class="font-mono text-sm font-bold uppercase tracking-[0.16em] text-[var(--mm-muted)]">
          {allNotes.length} notes
        </p>
      </div>

      {allNotes.length === 0 ? (
        <p class="text-[var(--mm-muted)]">No field notes published yet — check back soon.</p>
      ) : (
        <div class="grid gap-4">
          {allNotes.map((note) => (
            <article class="border-b border-[var(--mm-border)] pb-4">
              <div class="flex flex-wrap items-center gap-3">
                {note.data.noteType && (
                  <span class="mm-pill">{noteTypeLabel(note.data.noteType)}</span>
                )}
                {note.data.datePublished && (
                  <span class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-muted)]">
                    {formatDate(note.data.datePublished)}
                  </span>
                )}
              </div>
              <h3 class="mt-2 text-xl font-bold leading-tight">
                <a href={fieldNoteUrl(note)} class="hover:underline">{note.data.title}</a>
              </h3>
              {note.data.excerpt && (
                <p class="mt-2 text-sm leading-6 text-[var(--mm-muted)]">{note.data.excerpt}</p>
              )}
            </article>
          ))}
        </div>
      )}
    </section>
  </main>
</Layout>
