---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { fieldNoteUrl, isPublishedNote, noteTypeLabel } from '../../lib/field-notes';
import { slugifyTerm } from '../../lib/articles';

export async function getStaticPaths() {
  const notes = await getCollection('fieldNotes', isPublishedNote);
  return notes.map((note) => ({
    params: { slug: note.data.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

function formatDate(value: Date | null): string {
  if (!value) return '';
  return new Date(value).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

const pagefindAttrs = {
  'data-pagefind-body': true,
  'data-pagefind-filter': 'type[data-type]',
  'data-type': 'Field Note',
  'data-pagefind-meta': 'date[data-date]',
  'data-pagefind-sort': 'date[data-date]',
  'data-date': note.data.datePublished
    ? new Date(note.data.datePublished).toISOString().slice(0, 10)
    : '',
};
---

<Layout title={note.data.title} description={note.data.excerpt} canonical={fieldNoteUrl(note)}>
  <main>
    <article class="mm-container max-w-3xl py-12" {...pagefindAttrs}>
      <a href="/field-notes/" class="font-mono text-xs font-bold uppercase tracking-[0.12em] text-[var(--mm-orange-deep)] hover:underline" data-pagefind-ignore>Back to field notes</a>

      <div class="mt-5 flex flex-wrap items-center gap-3">
        {note.data.noteType && <span class="mm-pill">{noteTypeLabel(note.data.noteType)}</span>}
        {note.data.datePublished && (
          <span class="font-mono text-sm font-bold uppercase tracking-[0.12em] text-[var(--mm-muted)]">
            {formatDate(note.data.datePublished)}
          </span>
        )}
      </div>

      <h1 class="mm-h1 mt-4">{note.data.title}</h1>

      {note.data.tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {note.data.tags.map((tag) => (
            <a href={`/topics/${slugifyTerm(tag)}/`} class="mm-pill hover:border-[var(--color-border-strong)]">{tag}</a>
          ))}
        </div>
      )}

      <div class="mm-prose prose mt-10">
        <Content />
      </div>

      {note.data.snippets.length > 0 && (
        <section class="mt-10 border-t border-[var(--mm-border)] pt-8">
          <p class="mm-eyebrow">Related snippets</p>
          <dl class="mt-4 grid gap-3">
            {note.data.snippets.map((snippet) => (
              <div class="mm-card p-4">
                <dt class="font-mono text-base font-bold">{snippet.label}</dt>
                {snippet.detail && <dd class="mt-1 text-sm leading-6 text-[var(--mm-muted)]">{snippet.detail}</dd>}
              </div>
            ))}
          </dl>
        </section>
      )}

      {(note.data.relatedTutorialUrl || note.data.relatedResource?.slug) && (
        <section class="mt-10 flex flex-wrap gap-4 border-t border-[var(--mm-border)] pt-8" data-pagefind-ignore>
          {note.data.relatedTutorialUrl && (
            <a href={note.data.relatedTutorialUrl} class="font-mono text-sm font-bold uppercase tracking-[0.1em] text-[var(--mm-orange-deep)] hover:underline">
              Full tutorial -&gt;
            </a>
          )}
          {note.data.relatedResource?.slug && (
            <a href="/resources/" class="font-mono text-sm font-bold uppercase tracking-[0.1em] text-[var(--mm-orange-deep)] hover:underline">
              {note.data.relatedResource.name ? `About ${note.data.relatedResource.name}` : 'Related resource'} -&gt;
            </a>
          )}
        </section>
      )}
    </article>
  </main>
</Layout>
