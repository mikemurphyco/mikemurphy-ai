---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" description="This page doesn't exist. MurphBot checked every node and came back empty-handed.">
	<main class="mm-container mm-404 grid gap-14 py-16 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
		<div>
			<p class="mm-eyebrow">This is where people get stuck</p>
			<h1 class="mm-h1 mt-3">Error 404</h1>
			<p class="mm-lede mt-5">
				Whatever you were looking for isn't at this address. Maybe I moved it, maybe the link had a typo — either way, MurphBot checked every node and came back empty-handed.
			</p>
			<div class="mm-terminal mt-7">
				<div><span class="mm-muted">$ </span>murphbot --locate "this page"</div>
				<div class="mm-muted">searching 3 nodes… done</div>
				<div class="mm-muted">0 results found</div>
				<div>→ try: <a href="/">mikemurphy.ai/</a></div>
			</div>
			<div class="mt-7 flex flex-wrap gap-4">
				<a href="/" class="mm-button">Take me home</a>
				<a href="/tutorials/" class="mm-button mm-button-secondary">Browse the tutorials →</a>
			</div>
		</div>
		<div class="flex flex-col items-center gap-5">
			<svg
				class="mm-murphbot w-[220px] sm:w-[280px]"
				xmlns="http://www.w3.org/2000/svg"
				width="240"
				height="264"
				viewBox="0 0 240 264"
				role="img"
				aria-label="MurphBot, a small robot built from the Node mark, waving"
			>
				<title>MurphBot — Unit 404</title>
				<desc>Mike Murphy&#39;s MurphBot character, built from the Node mark. Orange head, navy satellites, one teal antenna dot. Self-animating (float, blink, wave).</desc>
				<g class="mb-body">
					<line x1="120" y1="118" x2="52" y2="196" class="mb-ink" stroke-width="2.5" stroke-linecap="round" opacity="0.6"></line>
					<line x1="120" y1="118" x2="176" y2="204" class="mb-ink" stroke-width="2" stroke-linecap="round" opacity="0.6"></line>
					<circle cx="52" cy="196" r="9" class="mb-ink-fill"></circle>
					<circle cx="176" cy="204" r="6.5" class="mb-ink-fill"></circle>
					<g class="mb-hand">
						<line x1="152" y1="76" x2="204" y2="40" class="mb-ink" stroke-width="2.5" stroke-linecap="round" opacity="0.6"></line>
						<circle cx="204" cy="40" r="8" class="mb-ink-fill"></circle>
					</g>
					<line x1="120" y1="52" x2="120" y2="26" class="mb-ink" stroke-width="2.5" stroke-linecap="round" opacity="0.6"></line>
					<circle cx="120" cy="20" r="7" fill="#1ECEBE"></circle>
					<circle cx="120" cy="104" r="52" fill="#FF6434"></circle>
					<g class="mb-eyes">
						<circle cx="101" cy="96" r="6.5" class="mb-ink-fill"></circle>
						<circle cx="139" cy="96" r="6.5" class="mb-ink-fill"></circle>
					</g>
					<path d="M 106 122 Q 120 132 134 122" class="mb-ink" stroke-width="4" stroke-linecap="round" fill="none"></path>
				</g>
			</svg>
			<p class="mm-404-caption">MurphBot · Unit 404<br />He looked everywhere.</p>
		</div>
	</main>
</Layout>

<style>
	.mm-404 {
		min-height: 60vh;
	}

	.mm-terminal {
		background: var(--color-bg-surface);
		border: 1px solid var(--color-border-strong);
		border-radius: var(--radius-md);
		box-shadow: var(--shadow-cut);
		font-family: var(--font-mono);
		font-size: var(--fs-code);
		line-height: var(--lh-code);
		max-width: 520px;
		padding: 18px 20px;
	}

	.mm-terminal a {
		color: var(--color-action-primary);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.mm-terminal a:hover {
		color: var(--color-action-primary-hover);
	}

	.mm-muted {
		color: var(--color-text-muted);
	}

	.mm-404-caption {
		color: var(--color-text-muted);
		font-family: var(--font-mono);
		font-size: var(--fs-mono-label);
		font-weight: 700;
		letter-spacing: var(--ls-eyebrow);
		text-align: center;
		text-transform: uppercase;
	}

	.mm-murphbot .mb-ink {
		stroke: var(--mm-navy);
	}

	.mm-murphbot .mb-ink-fill {
		fill: var(--mm-navy);
	}

	html[data-theme='dark'] .mm-murphbot .mb-ink {
		stroke: var(--mm-chalk);
	}

	html[data-theme='dark'] .mm-murphbot .mb-ink-fill {
		fill: var(--mm-chalk);
	}

	.mm-murphbot .mb-body {
		animation: mb-float 3.2s ease-in-out infinite;
		transform-box: fill-box;
		transform-origin: center;
	}

	.mm-murphbot .mb-eyes {
		animation: mb-blink 4.4s ease-in-out infinite;
		transform-box: fill-box;
		transform-origin: center;
	}

	.mm-murphbot .mb-hand {
		animation: mb-wave 2.1s ease-in-out infinite;
		transform-box: view-box;
		transform-origin: 152px 76px;
	}

	@keyframes mb-float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-6px); }
	}

	@keyframes mb-blink {
		0%, 92%, 100% { transform: scaleY(1); }
		96% { transform: scaleY(0.1); }
	}

	@keyframes mb-wave {
		0%, 100% { transform: rotate(0deg); }
		25% { transform: rotate(-18deg); }
		50% { transform: rotate(0deg); }
		75% { transform: rotate(-10deg); }
	}

	@media (prefers-reduced-motion: reduce) {
		.mm-murphbot .mb-body,
		.mm-murphbot .mb-eyes,
		.mm-murphbot .mb-hand {
			animation: none;
		}
	}
</style>
